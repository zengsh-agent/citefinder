# CiteFinder Environment Variables
# Copy this to .env and fill in your API keys

# LLM Provider: minimax, openai, or gemini
LLM_PROVIDER=minimax

# MiniMax (default for China)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Search APIs (optional)
SERPAPI_API_KEY=
TAVILY_API_KEY=
